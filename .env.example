# ─── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://app.tuclinica.com

# ─── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── WhatsApp (Baileys worker en Railway) ──────────────────────────────────────
WHATSAPP_WEBHOOK_SECRET=tu-secreto-muy-largo-aqui
CLINIC_SLUG=bellavista            # slug de la clínica para el worker de WhatsApp

# ─── Crons (Railway cron-runner) ───────────────────────────────────────────────
CRON_SECRET=tu-secreto-cron-aqui

# ─── Email — Resend ────────────────────────────────────────────────────────────
# Obtener en: resend.com
RESEND_API_KEY=re_...
RESEND_FROM=noreply@tuclinica.com  # dominio verificado en Resend

# ─── Facturación Electrónica — Alegra (opcional) ───────────────────────────────
# Sin estas variables la facturación funciona en modo local (sin envío a Hacienda)
# Obtener en: alegra.com/cr
ALEGRA_EMAIL=tu@email.com
ALEGRA_API_KEY=tu-alegra-api-key

# ─── Marketing — Configuración por clínica (en DB, no en .env) ────────────────
# Estos se configuran en clinics.settings (JSON) por clínica:
#   owner_email:             email del dueño para alertas
#   agent_tone:              formal | semi-formal | informal
#   max_discount_percent:    número (ej: 20)
#   google_review_link:      URL de Google Reviews
#   cedula_juridica:         cédula jurídica de la clínica (para facturas)
#   alegra_email:            (alternativo al ENV global, por clínica)
#   marketing_requires_approval: true | false

# ─── Stripe — Billing AaaS ────────────────────────────────────────────────────
# Obtener en: dashboard.stripe.com
STRIPE_SECRET_KEY=sk_live_...        # o sk_test_... para desarrollo
STRIPE_PUBLISHABLE_KEY=pk_live_...   # para el frontend (no usado aún)
STRIPE_WEBHOOK_SECRET=whsec_...      # del endpoint en dashboard.stripe.com/webhooks
# IDs de precios en Stripe (crear productos primero)
STRIPE_PRICE_STARTER=price_...       # $99/mes
STRIPE_PRICE_GROWTH=price_...        # $199/mes
STRIPE_PRICE_PREMIUM=price_...       # $299/mes

# ─── Railway Workers ───────────────────────────────────────────────────────────
# Estas variables van en el servicio de Railway (workers/):
#   NEXT_PUBLIC_APP_URL  (mismo valor)
#   CRON_SECRET          (mismo valor)
#   WHATSAPP_WEBHOOK_SECRET (mismo valor)
#   CLINIC_SLUG          (slug de la clínica)
